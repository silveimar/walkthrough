{
  "version": 4,
  "localOnly": {
    "default": true
  },
  "egress": {
    "defaultPosture": "deny_all",
    "exceptionAllowlist": [
      {
        "id": "claude_eval_prompt",
        "channels": ["claude_cli"]
      },
      {
        "id": "claude_llm_rubric",
        "channels": ["llm_rubric_claude"]
      }
    ]
  },
  "llmRubric": {
    "networkDefault": "off",
    "optInEnvVar": "WALKTHROUGH_LLM_RUBRIC"
  },
  "entrypoints": {
    "gatedRelPaths": [
      "evals/run.sh",
      "evals/graders/llm-rubric.mjs",
      "evals/graders/deterministic.mjs",
      "evals/report.mjs",
      ".github/workflows/static.yml"
    ]
  },
  "publish": {
    "approvedPathRoots": ["examples"]
  },
  "runtime": {
    "evalWorkspaceMustBeUnderSystemTemp": true,
    "allowedCliBinaries": ["claude", "node"]
  },
  "dataProtection": {
    "redaction": {
      "enabled": true
    },
    "retention": {
      "evalResultsMaxAgeDays": 30
    },
    "sensitiveOutputs": {
      "canonicalEvalResultsRelPath": "evals/results"
    }
  },
  "walkthroughViewerAssets": {
    "defaults": {
      "assetSource": "cdn",
      "vendorRootRel": "vendor/walkthrough-viewer"
    },
    "packages": {
      "react": { "assetSource": "cdn" },
      "reactDom": { "assetSource": "cdn" },
      "mermaid": { "assetSource": "cdn" },
      "tailwind": { "assetSource": "cdn" },
      "shiki": { "assetSource": "cdn" }
    }
  }
}
