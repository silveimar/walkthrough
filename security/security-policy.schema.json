{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://walkthrough-skill.local/security-policy.schema.json",
  "title": "Walkthrough skill security policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "localOnly", "egress", "llmRubric", "entrypoints", "publish", "walkthroughViewerAssets"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Policy document schema version (D-01). Bump when required keys or semantics change."
    },
    "localOnly": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default"],
      "properties": {
        "default": {
          "type": "boolean",
          "description": "localOnly.default — local-only mode default; must be true for maintainer-local posture (D-05 framing)."
        }
      }
    },
    "egress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultPosture", "exceptionAllowlist"],
      "properties": {
        "defaultPosture": {
          "type": "string",
          "enum": ["deny_all"],
          "description": "egress.defaultPosture — default egress posture; deny_all blocks network subprocesses unless exceptionAllowlist + explicit flags align (D-05, D-06)."
        },
        "exceptionAllowlist": {
          "type": "array",
          "description": "egress.exceptionAllowlist — ordered list of allowed egress exception ids; empty means no network egress (D-06). Each id may be referenced by per-run --allow-egress.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "channels"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "Opaque id matched by CLI/env allow flags (D-06)."
              },
              "channels": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "enum": ["claude_cli", "llm_rubric_claude"]
                },
                "description": "Channels this exception unlocks: claude_cli (evals/run.sh), llm_rubric_claude (llm-rubric grader)."
              }
            }
          }
        }
      }
    },
    "llmRubric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["networkDefault", "optInEnvVar"],
      "properties": {
        "networkDefault": {
          "type": "string",
          "enum": ["off"],
          "description": "llmRubric.networkDefault — LLM/rubric network off unless opt-in (D-08)."
        },
        "optInEnvVar": {
          "type": "string",
          "minLength": 1,
          "description": "llmRubric.optInEnvVar — env name; set to 1 to allow network rubric when policy permits (D-08)."
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gatedRelPaths"],
      "properties": {
        "gatedRelPaths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "entrypoints.gatedRelPaths — repo-relative paths that MUST load policy before doing work (D-09, D-10)."
        }
      }
    },
    "publish": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approvedPathRoots"],
      "properties": {
        "approvedPathRoots": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "publish.approvedPathRoots — path prefixes (relative to repo root) allowed for static publish artifact roots; use '.' for repo root (D-12)."
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evalWorkspaceMustBeUnderSystemTemp": {
          "type": "boolean",
          "description": "When true, eval harness temp dirs (mktemp) must resolve under Node os.tmpdir() (RUN-02)."
        },
        "allowedCliBinaries": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Expected CLI tool names for orchestration (documentation; enforcement via run.sh prerequisite checks)."
        }
      }
    },
    "dataProtection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "redaction": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "When false, skip redaction helpers (DATA-01)."
            }
          }
        },
        "retention": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "evalResultsMaxAgeDays": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3650,
              "description": "Delete eval result timestamp dirs older than this many days (DATA-02)."
            }
          }
        },
        "sensitiveOutputs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "canonicalEvalResultsRelPath": {
              "type": "string",
              "minLength": 1,
              "description": "Repo-relative root for bulk eval artifacts (DATA-03)."
            }
          }
        }
      }
    },
    "walkthroughViewerAssets": {
      "type": "object",
      "description": "Walkthrough HTML viewer script sources: per-package override → defaults (D-03, OFF-04).",
      "additionalProperties": false,
      "required": ["defaults", "packages"],
      "properties": {
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "required": ["assetSource", "vendorRootRel"],
          "properties": {
            "assetSource": {
              "type": "string",
              "enum": ["cdn", "vendor"],
              "description": "Default for all listed packages when not overridden. Precedence: packages.<id>.assetSource → defaults.assetSource."
            },
            "vendorRootRel": {
              "type": "string",
              "minLength": 1,
              "description": "Repo-relative root for vendored UMD/ESM/CSS (e.g. vendor/walkthrough-viewer)."
            }
          }
        },
        "packages": {
          "type": "object",
          "additionalProperties": false,
          "description": "Per-asset class overrides. Keys: react, reactDom, mermaid, tailwind, shiki.",
          "properties": {
            "react": {
              "type": "object",
              "additionalProperties": false,
              "required": ["assetSource"],
              "properties": {
                "assetSource": { "type": "string", "enum": ["cdn", "vendor"] }
              }
            },
            "reactDom": {
              "type": "object",
              "additionalProperties": false,
              "required": ["assetSource"],
              "properties": {
                "assetSource": { "type": "string", "enum": ["cdn", "vendor"] }
              }
            },
            "mermaid": {
              "type": "object",
              "additionalProperties": false,
              "required": ["assetSource"],
              "properties": {
                "assetSource": { "type": "string", "enum": ["cdn", "vendor"] }
              }
            },
            "tailwind": {
              "type": "object",
              "additionalProperties": false,
              "required": ["assetSource"],
              "properties": {
                "assetSource": { "type": "string", "enum": ["cdn", "vendor"] }
              }
            },
            "shiki": {
              "type": "object",
              "additionalProperties": false,
              "required": ["assetSource"],
              "properties": {
                "assetSource": { "type": "string", "enum": ["cdn", "vendor"] }
              }
            }
          }
        }
      }
    }
  }
}
